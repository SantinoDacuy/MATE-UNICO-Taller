{
  "kind": "collectionType",
  "collectionName": "productos",
  "info": {
    "singularName": "producto",
    "pluralName": "productos",
    "displayName": "Producto"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string"
    },
    "precio": {
      "type": "biginteger"
    },
    "descripcion": {
      "type": "text"
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "categoria": {
      "type": "enumeration",
      "enum": [
        "mate",
        "combo_simple",
        "combo_completo"
      ]
    },
    "color_negro": {
      "type": "boolean"
    },
    "color_marron": {
      "type": "boolean"
    },
    "color_blanco": {
      "type": "boolean"
    },
    "color_gris": {
      "type": "boolean"
    },
    "material": {
      "type": "enumeration",
      "enum": [
        "calabaza",
        "madera",
        "metal",
        "vidrio"
      ]
    },
    "modelo": {
      "type": "enumeration",
      "enum": [
        "imperial",
        "torpedo",
        "camionero"
      ]
    },
    "grabado": {
      "type": "boolean"
    },
    "stock": {
      "type": "integer",
      "default": 0,
      "min": 0
    }
  }
}
